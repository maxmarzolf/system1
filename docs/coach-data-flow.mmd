    A4["skillTags"]
    A5["elapsedMs / accuracy"]
  end

  subgraph ASSESSOR["1. Signal Assessor"]
    B["LLM call required"]
    S["signals"]
    M["assessment metadata"]

    S1["structure"]
    S2["correctness"]
    S3["completeness"]
    S4["patternFidelity"]
    S5["syntax"]
    S6["completionTime"]

    M1["patternIdentified"]
    M2["primaryBlocker"]
    M3["blockerKey"]
    M4["verdict"]
    M5["errorTags"]
    M6["strengths"]
  end

  subgraph LIVE["Live Feedback Path"]
    L1["liveMode = true"]
    L2["Live coach response"]
    L3["nextMove"]
    L4["why"]
    L5["affirmation"]
  end

  subgraph NARRATOR["2. Feedback Narrator"]
    N1["liveMode = false"]
    N2["LLM call required"]
    N3["Narrated feedback"]
    N4["fullFeedback"]
    N5["correctedVersion"]
    N6["microDrill"]
    N7["nextRepTarget"]
  end

  subgraph MEMORY["Stored Result"]
    R1["submissionRubric shape"]
    R2["attempt history"]
    R3["readiness / progress summary"]
  end

  subgraph GENERATOR["3. Practice Generator"]
    G1["LLM-only generation"]
    G2["Skill-map drill deck<br/>stream endpoint, then non-stream retry"]
    G3["Adaptive repair variation"]
  end

  subgraph NEXT["Next Practice"]
    P1["practice queue"]
    P2["next user attempt"]
  end

  subgraph ERROR["Failure Rule"]
    E1["No LLM provider"]
    E2["Invalid or empty LLM response"]
    E3["Structured HTTP / SSE error"]
    E4["Frontend shows unavailable state"]
  end

