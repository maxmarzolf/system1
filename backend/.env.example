# Backend runtime settings
PORT=3001
DATABASE_URL=postgresql://flashcard_user:flashcard_password@localhost:5432/flashcard_db
ADMIN_RESET_TOKEN=reset-practice-history

# Coach LLM settings
# Choose default provider used when request does not set llmProvider.
COACH_LLM_PROVIDER=openai

# Either COACH_OPENAI_API_KEY or OPENAI_API_KEY works.
COACH_OPENAI_API_KEY=
COACH_OPENAI_MODEL=gpt-5.2
COACH_OPENAI_BASE_URL=https://api.openai.com/v1

# Claude / Anthropic settings
COACH_ANTHROPIC_API_KEY=
COACH_ANTHROPIC_MODEL=claude-sonnet-4-6
COACH_ANTHROPIC_BASE_URL=https://api.anthropic.com/v1

# Gemma / Google Generative Language settings
COACH_GEMMA_API_KEY=
COACH_GEMMA_MODEL=gemma-4-31b-it
COACH_GEMMA_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# Generator tuning — output quality
# Maximum words allowed in a generated drill prompt.
COACH_GENERATOR_PROMPT_WORDS=12
# Hard character cap applied after word truncation.
COACH_GENERATOR_PROMPT_MAX_CHARS=80
# Patterns at or above this readiness score (0–100) are excluded from generation.
COACH_GENERATOR_READINESS_THRESHOLD=90.0

# Generator tuning — cost / latency
# Max tokens the LLM may return per generation request.
COACH_GENERATOR_MAX_TOKENS=8000
# Seconds before the LLM call is aborted.
COACH_GENERATOR_TIMEOUT_SECONDS=90
# LLM sampling temperature (0.0 = deterministic, 1.0 = most varied).
COACH_GENERATOR_TEMPERATURE=0.7
# How many recent pattern attempts to include as history context (0 = disabled).
COACH_GENERATOR_PATTERN_HISTORY_LIMIT=0
